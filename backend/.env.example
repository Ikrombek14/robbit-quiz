# Backend konfiguratsiyasi
PORT=4000
CLIENT_URL=http://localhost:5173

# Ma'lumotlar bazasi (SQLite — dev). Postgres uchun: postgresql://user:pass@localhost:5432/robbit
DATABASE_URL="file:./dev.db"

# JWT maxfiy kaliti (ishlab chiqarishda kuchli tasodifiy qiymat qo'ying)
JWT_SECRET="dev-secret-change-me"

# Claude AI kaliti (PDF -> savol generatsiyasi uchun)
ANTHROPIC_API_KEY="sk-ant-..."

# Google OAuth Client ID (admin Google bilan kirishi uchun)
# Google Cloud Console > APIs & Services > Credentials > OAuth client ID (Web)
GOOGLE_CLIENT_ID=""
