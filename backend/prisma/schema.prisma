// Robbit Akademiyasi quiz platformasi — DB sxemasi
// SQLite (dev). Production'da provider'ni "postgresql" ga o'zgartirish kifoya.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Teacher {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String? // Google orqali kirganlarda bo'lmaydi
  name      String
  picture   String? // Google avatar
  isAdmin   Boolean  @default(false)
  approved  Boolean  @default(false) // roster (ustozlar ro'yxati)ga ism-familiyasi mos kelsa true
  createdAt DateTime @default(now())
  quizzes   Quiz[]
}

// Rasmiy ustozlar ro'yxati (CSV'dan import qilinadi). Admin boshqaradi.
// Foydalanuvchi ismi-familiyasi shu yerdagi name'ga (nameKey orqali) mos kelsa
// — u "approved" bo'ladi va O'quv reja / Yo'riqnomaga kira oladi.
model RosterTeacher {
  id        String   @id @default(cuid())
  name      String // "Bobonova Gulnoza"
  branch    String? // Filial
  category  String? // Hozirgi toifasi (1/2/3)
  phone     String?
  username  String?
  status    String? // CSV status / guruh turi
  nameKey   String   @unique // normalize(name) — moslik va dedupe uchun
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  shuffle     Boolean  @default(false) // savollar tartibini aralashtirish
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slides      Slide[]
}

// Universal "slayd" — ham kontent slayd, ham savol bo'lishi mumkin.
// kind: "CONTENT" | "QUESTION"
// type (faqat QUESTION uchun): SINGLE | MULTIPLE | TRUE_FALSE | DROPDOWN |
//                              POLL | OPEN | FILL_BLANK | MATCH | REORDER
// data: turga qarab JSON (matn, variantlar, javoblar, juftliklar va h.k.)
model Slide {
  id        String  @id @default(cuid())
  quizId    String
  quiz      Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order     Int     @default(0)
  kind      String  @default("QUESTION")
  type      String?
  data      String  @default("{}")
  notes     String?
  timeLimit Int     @default(20)
  points    Int     @default(1000)
}

// O'ynalgan o'yin natijasi (hisobot uchun)
model GameRecord {
  id            String             @id @default(cuid())
  teacherId     String
  quizId        String
  title         String
  pin           String
  mode          String             @default("LIVE") // LIVE | HOMEWORK
  totalSlides   Int                @default(0)
  questionStats String             @default("[]") // JSON: [{index,text,correct,total}]
  playedAt      DateTime           @default(now())
  players       GamePlayerRecord[]
}

model GamePlayerRecord {
  id            String     @id @default(cuid())
  gameId        String
  game          GameRecord @relation(fields: [gameId], references: [id], onDelete: Cascade)
  nickname      String
  score         Int        @default(0)
  correctCount  Int        @default(0)
  totalAnswered Int        @default(0)
  details       String     @default("[]") // TEST rejimi: har savol bo'yicha JSON [{index,text,answer,correct,timeMs,correctAns}]
}

// Ustozlar yo'riqnomasi: bo'limlarga ajratilgan qo'llanma
// Har bir bo'lim — sarlavha + markdown matn. Admin tahrirlaydi/o'chiradi/qo'shadi.
model GuideSection {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  title     String
  body      String   @default("") // markdown matn
  icon      String?  // material symbol nomi (ixtiyoriy)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// O'quv dastur: dars rejalar
// subject: ROBOTEXNIKA | DASTURLASH
// ageGroup: JUNIOR | MIDDLE | SENIOR
// year: 1 | 2
// section: DESIGN | PROGRAMMING | ROBOTICS (faqat ROBOTEXNIKA uchun, DASTURLASH'da null)
model LessonPlan {
  id        String   @id @default(cuid())
  subject   String   // ROBOTEXNIKA | DASTURLASH
  ageGroup  String   // JUNIOR | MIDDLE | SENIOR
  year      Int      // 1 | 2
  section   String?  // DESIGN | PROGRAMMING | ROBOTICS
  order     Int      @default(0)
  title     String
  author    String?
  isDemo    Boolean  @default(false)
  quizId    String?  // biriktrilgan quiz (ixtiyoriy)
  createdAt DateTime @default(now())
}
